<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Кнопка 3: Настройки вынесена наверх с отступом -->
        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/settings_title"
            android:backgroundTint="#795548"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Кнопка 1: Крупная и полностью доступная -->
        <Button
            android:id="@+id/btnCreateOffer"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/create_new_room"
            android:backgroundTint="#673AB7"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- Кнопка 2 -->
        <Button
            android:id="@+id/btnAcceptSdp"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/enter_on_pin_by"
            android:backgroundTint="#673AB7"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="12dp" />

        <!-- Статус подключения -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/status_wait_doing"
            android:textColor="#FF5722"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Поле обмена кодами комнаты -->
        <EditText
            android:id="@+id/etSdpExchange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/pin_code"
            android:inputType="textLongMessage"
            android:drawableEnd="@android:drawable/ic_menu_close_clear_cancel"
            android:importantForAutofill="no"
            android:drawablePadding="8dp"
            android:layout_marginTop="12dp" />

        <!-- Лог чата -->
        <TextView
            android:id="@+id/tvChatHistory"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="24dp"
            android:background="#FAFFAF"
            android:padding="8dp"
            android:scrollbars="vertical"
            android:text="@string/history_sms"
            android:textColor="#333333"
            android:textSize="16sp" />

        <!-- Панель ввода сообщений -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnAttachFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📎" />


            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="@string/sms"
                android:importantForAutofill="no"
                android:textColor="#212121" />

            <Button
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sms_push"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
